{
  "manifest_version": 3,
  "name": "SpammerZ",
  "version": "1.0.5",
  "description": "Bulk submit Google Forms with random answers — serverless",
  "author": "SpammerZ",

  "permissions": [
    "activeTab"
  ],

  "host_permissions": [
    "*://docs.google.com/forms/*",
    "https://api.country.is/*",
    "https://api.geocoded.me/*",
    "https://psgc.cloud/*",
    "https://api.zippopotam.us/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://docs.google.com/forms/*"],
      "js": ["ui/panel.js", "content/content.js"],
      "css": ["ui/panel.css"],
      "run_at": "document_end"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["ui/panel.js", "ui/panel.css", "icons/*", "Names/FirstName/firstname.md", "Names/LastName/lastname.md", "options/courses.md", "options/profession.md"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
