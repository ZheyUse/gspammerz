{
  "manifest_version": 3,
  "name": "SpammerZ",
  "version": "1.0",
  "description": "Bulk submit Google Forms with random answers — serverless",
  "author": "SpammerZ",

  "permissions": [
    "activeTab"
  ],

  "host_permissions": [
    "*://docs.google.com/forms/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://docs.google.com/forms/*"],
      "js": ["ui/panel.js", "content/content.js"],
      "css": ["ui/panel.css"],
      "run_at": "document_end"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["ui/panel.js", "ui/panel.css", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}